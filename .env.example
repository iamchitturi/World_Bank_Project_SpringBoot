# ---- Local default (no MySQL required) ----
DB_URL=jdbc:h2:file:./data/bankdb;MODE=MySQL;AUTO_SERVER=TRUE
DB_DRIVER=org.h2.Driver
DB_USERNAME=sa
DB_PASSWORD=
FLYWAY_ENABLED=true

